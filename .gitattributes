# Auto-detect text files and normalize line endings to LF in repo
* text=auto eol=lf

# Explicit binary files (no normalization)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.mp4 binary
*.mov binary
*.webm binary
*.pdf binary
*.zip binary
*.jar binary
*.keystore binary
*.jks binary
*.p12 binary
*.mobileprovision binary
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary

# Shell scripts must stay LF even on Windows checkout
*.sh text eol=lf
*.bash text eol=lf

# Windows scripts must stay CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf
